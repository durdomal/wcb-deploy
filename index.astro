---
import Base from '@/layouts/Base.astro';
import TrustBar from '@/components/TrustBar.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import ProductCard from '@/components/ProductCard.astro';
import QuickBook from '@/components/QuickBook.astro';
import { useTranslations, localizedPath, locales, defaultLang, type Lang } from '@/i18n/utils';
import { getProductsByMode, eur } from '@/lib/products';
import { whatsappLink } from '@/lib/site';

const langParam = Astro.params.lang as string;
if (!(locales as string[]).includes(langParam)) {
  return Astro.redirect(localizedPath(defaultLang), 302);
}
const lang = langParam as Lang;
const t = useTranslations(lang);

const rentProducts = await getProductsByMode('rent');
const saleProducts = await getProductsByMode('sale');

const uspByLang: Record<string, { big: string; small: string }[]> = {
  es: [
    { big: 'Desde 25 €/día', small: 'Tarifas transparentes' },
    { big: 'Depósito 100 €', small: 'El más bajo de la zona' },
    { big: 'Entrega gratis', small: 'En toda la Costa Blanca' },
    { big: 'Equipo completo', small: 'Remo, hinchador, leash y mochila' },
  ],
  en: [
    { big: 'From €25/day', small: 'Transparent pricing' },
    { big: '€100 deposit', small: 'Lowest in the area' },
    { big: 'Free delivery', small: 'Across the Costa Blanca' },
    { big: 'Full kit included', small: 'Paddle, pump, leash & backpack' },
  ],
  de: [
    { big: 'Ab 25 €/Tag', small: 'Transparente Preise' },
    { big: '100 € Kaution', small: 'Die niedrigste der Region' },
    { big: 'Gratis Lieferung', small: 'An der ganzen Costa Blanca' },
    { big: 'Komplettes Set', small: 'Paddel, Pumpe, Leash & Rucksack' },
  ],
  ru: [
    { big: 'От 25 €/день', small: 'Прозрачные тарифы' },
    { big: 'Залог 100 €', small: 'Самый низкий в районе' },
    { big: 'Доставка бесплатно', small: 'По всей Коста-Бланке' },
    { big: 'Полный комплект', small: 'Весло, насос, лиш и рюкзак' },
  ],
};
const usp = uspByLang[lang] ?? uspByLang.es;

const lifeByLang: Record<string, { title: string; sub: string }> = {
  es: { title: 'Vive la Costa Blanca', sub: 'Amaneceres, calas escondidas y agua turquesa — listo para tu próxima aventura sobre el agua.' },
  en: { title: 'Live the Costa Blanca', sub: 'Sunrises, hidden coves and turquoise water — ready for your next adventure on the water.' },
  de: { title: 'Erlebe die Costa Blanca', sub: 'Sonnenaufgänge, versteckte Buchten und türkises Wasser — bereit für dein nächstes Abenteuer auf dem Wasser.' },
  ru: { title: 'Живи Коста-Бланкой', sub: 'Рассветы, скрытые бухты и бирюзовая вода — готов к новому приключению на воде.' },
};
const life = lifeByLang[lang] ?? lifeByLang.es;
const lifePhotos = ['/images/life-1.webp', '/images/life-2.webp', '/images/life-3.webp'];

const heroTrustByLang: Record<string, string> = {
  es: 'Depósito 100 € · Entrega gratis · Equipo completo · 4 idiomas',
  en: '€100 deposit · Free delivery · Full kit · 4 languages',
  de: '100 € Kaution · Gratis Lieferung · Komplettes Set · 4 Sprachen',
  ru: 'Залог 100 € · Доставка бесплатно · Полный комплект · 4 языка',
};
const heroTrust = heroTrustByLang[lang] ?? heroTrustByLang.es;

const ctaWaByLang: Record<string, string> = {
  es: 'Reservar por WhatsApp', en: 'Book on WhatsApp', de: 'Per WhatsApp buchen', ru: 'Забронировать в WhatsApp',
};
const ctaWa = ctaWaByLang[lang] ?? ctaWaByLang.es;
const verByLang: Record<string, string> = {
  es: 'Ver tablas', en: 'See boards', de: 'Boards ansehen', ru: 'Смотреть доски',
};
const verTablas = verByLang[lang] ?? verByLang.es;
const waHeroByLang: Record<string, string> = {
  es: '¡Hola! Quiero alquilar una tabla de SUP en la Costa Blanca. ¿Me ayudáis con la disponibilidad?',
  en: 'Hi! I would like to rent a SUP board on the Costa Blanca. Can you help me with availability?',
  de: 'Hallo! Ich möchte ein SUP-Board an der Costa Blanca mieten. Könnt ihr mir mit der Verfügbarkeit helfen?',
  ru: 'Здравствуйте! Хочу арендовать SUP-доску на Коста-Бланке. Подскажете по доступности?',
};
const waHero = waHeroByLang[lang] ?? waHeroByLang.es;

const splitByLang: Record<string, { rentHook: string; buyHook: string }> = {
  es: { rentHook: 'Por días, desde 25 €', buyHook: 'Tu tabla nueva por 190 €' },
  en: { rentHook: 'By the day, from €25', buyHook: 'Your new board for €190' },
  de: { rentHook: 'Tageweise, ab 25 €', buyHook: 'Dein neues Board für 190 €' },
  ru: { rentHook: 'Посуточно, от 25 €', buyHook: 'Новая доска за 190 €' },
};
const split = splitByLang[lang] ?? splitByLang.es;
---
<Base lang={lang}>
  <section class="relative overflow-hidden bg-gradient-to-b from-sea-50 to-white">
    <div class="container-page grid items-center gap-10 py-10 lg:grid-cols-2 lg:py-16">
      <div>
        <p class="mb-4 inline-flex rounded-full bg-sea-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-sea-700">Dénia · Costa Blanca</p>
        <h1 class="text-4xl font-extrabold leading-[1.05] tracking-tight text-ink sm:text-5xl lg:text-6xl">{t('hero.title')}</h1>
        <p class="mt-5 max-w-md text-lg text-ink-soft">{t('hero.subtitle')}</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-3 text-base font-bold text-white shadow-md transition hover:brightness-95" href={whatsappLink(waHero)} target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.157 5.335 5.493 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.737-.979z"/></svg>
            {ctaWa}
          </a>
          <a class="btn-ghost" href={localizedPath(lang, 'alquiler')}>{verTablas}</a>
        </div>
        <p class="mt-4 flex items-center gap-2 text-sm font-medium text-ink-soft">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-sea-600"><path d="M20 6 9 17l-5-5"/></svg>
          {heroTrust}
        </p>
      </div>
      <div class="relative aspect-[4/5] w-full overflow-hidden rounded-2xl shadow-xl">
        <img src="/images/hero.webp" alt={t('hero.title')} width="960" height="1200" fetchpriority="high" decoding="async" class="h-full w-full object-cover" />
      </div>
    </div>
  </section>

  <QuickBook lang={lang} />

  <TrustBar lang={lang} />

  <section class="container-page py-12">
    <div class="grid gap-6 lg:grid-cols-2">
      <a href={localizedPath(lang, 'alquiler')} class="group relative block aspect-[16/10] overflow-hidden rounded-3xl shadow-lg sm:aspect-[2/1]">
        <img src="/images/hero.webp" alt={t('home.rent.title')} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-7">
          <p class="text-xs font-semibold uppercase tracking-wider text-white/80">{split.rentHook}</p>
          <h2 class="mt-1 text-2xl font-extrabold text-white sm:text-3xl">{t('home.rent.title')}</h2>
          <span class="mt-4 inline-flex items-center rounded-full bg-white px-5 py-2.5 text-sm font-bold text-ink transition group-hover:bg-sea-50">{t('nav.rent')} <span class="ml-1.5">→</span></span>
        </div>
      </a>
      <a href={localizedPath(lang, 'venta')} class="group relative block aspect-[16/10] overflow-hidden rounded-3xl shadow-lg sm:aspect-[2/1]">
        <img src="/images/beach.webp" alt={t('home.buy.title')} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-7">
          <p class="text-xs font-semibold uppercase tracking-wider text-white/80">{split.buyHook}</p>
          <h2 class="mt-1 text-2xl font-extrabold text-white sm:text-3xl">{t('home.buy.title')}</h2>
          <span class="mt-4 inline-flex items-center rounded-full bg-sea-600 px-5 py-2.5 text-sm font-bold text-white transition group-hover:bg-sea-700">{t('nav.buy')} <span class="ml-1.5">→</span></span>
        </div>
      </a>
    </div>
  </section>

  <section class="container-page py-8">
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      {usp.map((u) => (
        <div class="rounded-2xl border border-ink/10 bg-white p-5 text-center transition hover:border-sea-300 hover:shadow-lg">
          <p class="text-lg font-extrabold text-sea-600 sm:text-xl">{u.big}</p>
          <p class="mt-1 text-sm text-ink-soft">{u.small}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page py-10">
    <div class="mb-6 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-extrabold tracking-tight text-ink sm:text-3xl">{t('home.rent.title')}</h2>
      <a href={localizedPath(lang, 'alquiler')} class="shrink-0 text-sm font-semibold text-sea-600 hover:text-sea-700">{t('nav.rent')} →</a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {rentProducts.map((p) => <ProductCard product={p} lang={lang} mode="rent" />)}
    </div>
  </section>

  <section class="container-page py-10">
    <div class="mb-6 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-extrabold tracking-tight text-ink sm:text-3xl">{t('home.buy.title')}</h2>
      <a href={localizedPath(lang, 'venta')} class="shrink-0 text-sm font-semibold text-sea-600 hover:text-sea-700">{t('nav.buy')} →</a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {saleProducts.map((p) => <ProductCard product={p} lang={lang} mode="sale" />)}
    </div>
  </section>

  <section class="container-page py-12">
    <div class="mb-8 max-w-2xl">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink">{life.title}</h2>
      <p class="mt-3 text-ink-soft">{life.sub}</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      {lifePhotos.map((src) => (
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl shadow-md">
          <img src={src} alt={life.title} width="800" height="600" loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-500 hover:scale-105" />
        </div>
      ))}
    </div>
  </section>

  <HowItWorks lang={lang} />
</Base>
